# Copy to IDE / Render / shell. Optional: JWKS default is set in application.properties for instance sensible-boa-35.

# Override if you use another Clerk instance:
# CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# --- Database (PostgreSQL / Supabase) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/skillmentor
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Optional ---
PORT=8081
JPA_DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
